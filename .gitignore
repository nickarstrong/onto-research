# onto-research/.gitignore -- PUBLIC repo. NEVER publish held-out / bait / runtime.
# (pack v244/v245 sec 3.0 + 3.2: held-out poisons the measurement if eaten by a
#  future pretrain; bait + weights are local-only. Public git carries ONLY datable
#  provenance + reproducibility: data + scripts + gate.log + reports.)

# ── held-out: ALL files with 'heldout' in the name, any depth, any extension ──
# data AND generators. Leak = measurement death. A deterministic generator is as
# disclosive as the data, so it stays local BY DEFAULT. To publish a specific
# generator as a reproducibility script, add an explicit negation below, e.g.:
#   !lab/dpo/make_heldout_prompts_v1.py
*heldout*
**/*heldout*

# bait sets + manual bait verdicts (any depth)
*bait*
**/*bait*

# held-out / bait / runtime data + log dirs (lab siblings -- the live landmine)
lab/data/
lab/logs/

# runtime tier state / curated view (rebuilt each run; NOT provenance -- pack sec 1)
o0_tier_state.json
o0_verdicts_curated.jsonl
**/o0_tier_state.json
**/o0_verdicts_curated.jsonl

# backups / caches
*.bak.*
**/*.bak.*
__pycache__/
**/__pycache__/

# -- hardened v253 (OWED-3): self-model / sealed labels / goal stack (runtime identity) --
self_model.json
self_model.demo.json
**/self_model*.json
sealed_labels*
**/sealed_labels*
goal_stack.json
**/goal_stack.json

# -- weights / adapters / venv / vendored runtimes / GOLD (local only) --
adapters/
**/adapters/
**/adapter_*/
lab/models/
lab/venv/
lab/gold/
lab/llama-cpp/
*.bin
**/*.bin
*.gguf
**/*.gguf

# -- .md.bak style (existing *.bak.* misses trailing .bak) --
*.bak
**/*.bak

# -- GATE_selflearn held-out / answer-keys / derived-state (local only; never public) --
**/*_pairs_gold.json
**/*founder_labels.jsonl
**/*heldout*
**/*held_out*
**/o0_verdicts.jsonl
**/o0_verdicts_curated.jsonl
**/o0_verdicts_pool*.jsonl
# -- build clutter (source bundles, not deliverables) --
lab/dpo/*_out.zip
# -- v259 (OWED-3): hard-topics set is BAIT-DERIVED (src bait_v2_n32.jsonl); bait-named-free
#    so *bait* missed it. topic set + meta + recite-control = LOCAL ONLY. leak -> a future
#    pretrain eats it -> F1 HEADROOM signal poisoned. mechanism (controller.py + smoke) is
#    public and embeds no bait strings.
**/hard_topics*
**/fresh_topics*

# v260: --hard-topics traces embed hard-topic strings -> LOCAL only
lab/dpo/hl_baseline*.jsonl
lab/dpo/hl_baseline*.jsonl.frozen*
lab/dpo/o0_year_offline_table.jsonl

# v277 close-out: local-only substrate, never public
lab/dpo/eval/o0/o0_verdicts*
lab/dpo/eval/o0/swap_delta_*
lab/dpo/eval/o0/SUBSTRATE.md5
lab/dpo/eval/o0/c2_migration_delta.md
lab/dpo/*_delta.md
lab/dpo/eval/o0/*_delta.md
